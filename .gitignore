frontend/node_modules

# Server-side runtime state (lives on prod, never commit). Without these the prod
# working tree shows thousands of untracked files and `git status` is unusable,
# which hides real strays. Patterns chosen to avoid the tracked files under
# backend/data/ (fonts/, benchmarks/*.tsv, kalila_dove.*, frequency_sources/, *_progress.json).
.codex/
backend/data/audio/
backend/data/story-audio/
backend/data/book-uploads/
backend/data/voice-samples/
backend/data/*.db.backup*
backend/data/*.jsonl.gz
backend/data/*.log
backend/data/*_audit.json
backend/data/*_cleanup.json
backend/data/step4b_tag_progress.json
backend/data/*.tsv
polyglot/polyglot.db.*
polyglot/data/*.jsonl
polyglot/data/textbooks/
