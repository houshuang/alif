GEMINI_KEY=              # OCR/Vision only — all text LLM goes through Claude/Codex CLI (free)
OPENAI_KEY=              # API fallback when Claude CLI unavailable
ANTHROPIC_API_KEY=       # API fallback when Claude CLI unavailable
ELEVENLABS_API_KEY=
DATABASE_URL=sqlite:///./alif.db

# Codex routing (default since 2026-05-26 — see backend/app/services/codex_cli.py).
# The `claude_haiku` alias (audit + enrichment) routes through Codex `gpt-5.5`
# CLI by default. Set ALIF_AUDIT_PROVIDER=claude to opt out (escape hatch if
# Codex breaks). `claude_sonnet` (generation) is never routed through Codex.
# ALIF_AUDIT_PROVIDER=codex
# ALIF_CODEX_MODEL=gpt-5.5
# ALIF_CODEX_REASONING_EFFORT=medium
# ALIF_CODEX_HOME=          # only needed if codex auth is not in ~/.codex (e.g. /opt/alif/.codex on prod)
