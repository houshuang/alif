raqada", "freq_rank": null, "count_in_text": 3, "example_ar": "وصدحت موسيقى رائعة وأقامت المدينة على شرف منقذيها موكبًا من الشعل لم يقم مثله أناس من قبل أبدًا فى الطول والبهاء وفى نفس الوقت رقد بيبو العجوز على فراشه ولم يستطع النوم", "lemma_source": "camel"}, {"surface": "الطابور", "surface_forms": ["الطابور", "طابور"], "lemma_ar": "طابُور", "lemma_ar_bare": "طابور", "root": "ط.ب.ر", "gloss_en": "queue", "pos": "noun", "is_proper_noun": false, "register": null, "dialect": null, "transliteration": "ṭābūr", "freq_rank": null, "count_in_text": 11, "example_ar": "بين السور المعدنى والدواليب الزجاجية إندس طابور من الناس ببطء وكل فرد أخذ لنفسه من هنا وهناك طبقًا أو زجاجة وكوبًا من الورق المقوى", "lemma_source": "database"}, {"surface": "ومشت", "surface_forms": ["ومشت", "ومشى"], "lemma_ar": "مَشَّ", "lemma_ar_bare": "مش", "root": "م.ش.ش", "gloss_en": "to suck the marrow from (a bone)", "pos": "verb", "is_proper_noun": false, "register": null, "dialect": null, "transliteration": "mashsha", "freq_rank": null, "count_in_text": 7, "example_ar": "ومشت بصينيتها إلى إحدى المناضد الصغيرة كشكل نبات عش الغراب ولحقت بالفعل مكانًا بعد انتظار قليل", "lemma_source": "database"}, {"surface": "يلى", "surface_forms": ["يلى"], "lemma_ar": "يَلِي", "lemma_ar_bare": "يلي", "root": null, "gloss_en": "follows", "pos": "verb", "is_proper_noun": false, "register": "neutral", "dialect": "msa", "transliteration": "yalī", "freq_rank": null, "count_in_text": 7, "example_ar": "يلى : توجد نفائس و أوجه للثراء يمكن أن يهلك المرء بها إذا لم يستطع", "lemma_source": "surface_fallback"}, {"surface": "درعها", "surface_forms": ["درعها", "الدرع"], "lemma_ar": "دِرْعٌ", "lemma_ar_bare": "درع", "root": "د.ر.ع", "gloss_en": "shield", "pos": "noun", "is_proper_noun": false, "register": null, "dialect": null, "transliteration": "dirʿ", "freq_rank": null, "count_in_text": 6, "example_ar": "وكتب على الدرع : \" أنا معك", "lemma_source": "database"}, {"surface": "توقفت", "surface_forms": ["توقفت", "وتوقفت"], "lemma_ar":